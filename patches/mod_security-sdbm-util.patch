-cflags= $(includes) /nologo /DWIN32 /DWINNT /D_WINDOWS /Dinline=APR_INLINE /w /Zf /Zi /FS /O2 /GL /MD /DNDEBUG
+cflags= $(includes) /nologo /DWIN32 /DWINNT /D_WINDOWS /DNDEBUG
 
