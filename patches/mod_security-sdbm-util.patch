diff --git a/Makefile.win b/Makefile.win
index e28db0a..8bc3797 100644
--- a/Makefile.win
+++ b/Makefile.win
@@ -16,13 +16,13 @@ includes = -I$(APRUTIL)\include -I$(APR)\include
 
